<!--
  Warehouse scene for Sionna ray-tracing (Mitsuba 2.1.0 format)

  Materials use ITU names so Sionna applies correct radio properties:
    - itu_concrete : walls, floor, ceiling
    - itu_metal    : metal shelving racks
    - itu_wood     : wooden crates and pallets
-->
<scene version="2.1.0">

<!-- Rendering settings (used by Sionna internally) -->

        <integrator type="path">
                <integer name="max_depth" value="12"/>
        </integrator>

<!-- ======================== Materials ======================== -->

        <!-- Concrete: walls, floor, ceiling -->
        <bsdf type="twosided" id="mat-itu_concrete">
                <bsdf type="diffuse">
                        <rgb value="0.5 0.5 0.5" name="reflectance"/>
                </bsdf>
        </bsdf>

        <!-- Metal: shelving racks -->
        <bsdf type="twosided" id="mat-itu_metal">
                <bsdf type="diffuse">
                        <rgb value="0.6 0.6 0.65" name="reflectance"/>
                </bsdf>
        </bsdf>

        <!-- Wood: crates and pallets -->
        <bsdf type="twosided" id="mat-itu_wood">
                <bsdf type="diffuse">
                        <rgb value="0.7 0.5 0.3" name="reflectance"/>
                </bsdf>
        </bsdf>

<!-- ======================== Lighting ======================== -->

        <emitter type="constant" id="World">
                <rgb value="1.0 1.0 1.0" name="radiance"/>
        </emitter>

<!-- ======================== Shapes ========================== -->

        <!-- Floor -->
        <shape type="obj" id="mesh-floor">
                <string name="filename" value="meshes/floor.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_concrete" name="bsdf"/>
        </shape>

        <!-- Ceiling -->
        <shape type="obj" id="mesh-ceiling">
                <string name="filename" value="meshes/ceiling.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_concrete" name="bsdf"/>
        </shape>

        <!-- Walls (all 5 wall segments in one mesh) -->
        <shape type="obj" id="mesh-walls">
                <string name="filename" value="meshes/walls.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_concrete" name="bsdf"/>
        </shape>

        <!-- Shelf NW -->
        <shape type="obj" id="mesh-shelf_nw">
                <string name="filename" value="meshes/shelf_nw.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_metal" name="bsdf"/>
        </shape>

        <!-- Shelf NE -->
        <shape type="obj" id="mesh-shelf_ne">
                <string name="filename" value="meshes/shelf_ne.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_metal" name="bsdf"/>
        </shape>

        <!-- Shelf SW -->
        <shape type="obj" id="mesh-shelf_sw">
                <string name="filename" value="meshes/shelf_sw.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_metal" name="bsdf"/>
        </shape>

        <!-- Shelf SE -->
        <shape type="obj" id="mesh-shelf_se">
                <string name="filename" value="meshes/shelf_se.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_metal" name="bsdf"/>
        </shape>

        <!-- Crate 1 -->
        <shape type="obj" id="mesh-crate_1">
                <string name="filename" value="meshes/crate_1.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_wood" name="bsdf"/>
        </shape>

        <!-- Crate 2 -->
        <shape type="obj" id="mesh-crate_2">
                <string name="filename" value="meshes/crate_2.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_wood" name="bsdf"/>
        </shape>

        <!-- Crate 3 -->
        <shape type="obj" id="mesh-crate_3">
                <string name="filename" value="meshes/crate_3.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_wood" name="bsdf"/>
        </shape>

        <!-- Pallet -->
        <shape type="obj" id="mesh-pallet">
                <string name="filename" value="meshes/pallet.obj"/>
                <boolean name="face_normals" value="true"/>
                <ref id="mat-itu_wood" name="bsdf"/>
        </shape>

</scene>
